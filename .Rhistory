install.packages("tinytex")
tinytex::install_tinytex()
tinytex::is_tinytex()
tinytex::pdflatex("--version")
system("pdflatex --version")
install.packages("bookdown")
knitr::opts_chunk$set(include = FALSE, message = FALSE, warning = FALSE)
library(sandwich)
library(lmtest)
library(ggplot2)
# Pilot data: Test phase completion times (minutes)
# Control group (4 participants)
control_times <- c(6.3, 14.5, 11.07, 11.37)
# Video group (4 participants)
video_times <- c(8.25, 14, 7.92, 12.02)
# AI Tutor group (2 participants)
ai_times <- c(12.52, 1.92)
# Combined
all_times <- c(control_times, video_times, ai_times)
# Baseline parameters
control_mean_time <- mean(control_times)
pooled_sd_time    <- sd(all_times)
pilot_summary <- data.frame(
Group = c("Control", "Video Tutorial", "AI Tutor", "Overall"),
N = c(length(control_times), length(video_times),
length(ai_times), length(all_times)),
Mean_Time = round(c(mean(control_times), mean(video_times),
mean(ai_times), mean(all_times)), 2),
SD_Time = round(c(sd(control_times), sd(video_times),
sd(ai_times), sd(all_times)), 2)
)
colnames(pilot_summary) <- c("Group", "N", "Mean Time (min)", "SD (min)")
knitr::kable(pilot_summary, caption = "Pilot Data Summary Statistics")
set.seed(241)
n_sims <- 1000
sample_sizes <- c(5, 10, 15, 20, 30, 50)
s1_power <- numeric(length(sample_sizes))
for (j in seq_along(sample_sizes)) {
n_per_group <- sample_sizes[j]
significant <- 0
for (i in 1:n_sims) {
control <- rnorm(n_per_group, mean = control_mean_time, sd = pooled_sd_time)
video   <- rnorm(n_per_group, mean = control_mean_time - 0.5, sd = pooled_sd_time)
ai      <- rnorm(n_per_group, mean = control_mean_time - 1, sd = pooled_sd_time)
df <- data.frame(
time = c(control, video, ai),
treatment = factor(rep(c("Control", "Video", "AI"), each = n_per_group))
)
model <- lm(time ~ treatment, data = df)
robust_test <- coeftest(model, vcov = vcovHC(model, type = "HC1"))
if (any(robust_test[2:3, 4] < 0.05)) {
significant <- significant + 1
}
}
s1_power[j] <- significant / n_sims
}
s1_table <- data.frame(N_Per_Group = sample_sizes, Power = s1_power)
colnames(s1_table) <- c("N Per Group", "Power")
knitr::kable(s1_table, caption = "Scenario 1: Small Effect (AI 1 min faster, Video 0.5 min faster)")
s2_power <- numeric(length(sample_sizes))
for (j in seq_along(sample_sizes)) {
n_per_group <- sample_sizes[j]
significant <- 0
for (i in 1:n_sims) {
control <- rnorm(n_per_group, mean = control_mean_time, sd = pooled_sd_time)
video   <- rnorm(n_per_group, mean = control_mean_time - 1.5, sd = pooled_sd_time)
ai      <- rnorm(n_per_group, mean = control_mean_time - 3, sd = pooled_sd_time)
df <- data.frame(
time = c(control, video, ai),
treatment = factor(rep(c("Control", "Video", "AI"), each = n_per_group))
)
model <- lm(time ~ treatment, data = df)
robust_test <- coeftest(model, vcov = vcovHC(model, type = "HC1"))
if (any(robust_test[2:3, 4] < 0.05)) {
significant <- significant + 1
}
}
s2_power[j] <- significant / n_sims
}
s2_table <- data.frame(N_Per_Group = sample_sizes, Power = s2_power)
colnames(s2_table) <- c("N Per Group", "Power")
knitr::kable(s2_table, caption = "Scenario 2: Medium Effect (AI 3 min faster, Video 1.5 min faster)")
s3_power <- numeric(length(sample_sizes))
for (j in seq_along(sample_sizes)) {
n_per_group <- sample_sizes[j]
significant <- 0
for (i in 1:n_sims) {
control <- rnorm(n_per_group, mean = control_mean_time, sd = pooled_sd_time)
video   <- rnorm(n_per_group, mean = control_mean_time - 2.5, sd = pooled_sd_time)
ai      <- rnorm(n_per_group, mean = control_mean_time - 5, sd = pooled_sd_time)
df <- data.frame(
time = c(control, video, ai),
treatment = factor(rep(c("Control", "Video", "AI"), each = n_per_group))
)
model <- lm(time ~ treatment, data = df)
robust_test <- coeftest(model, vcov = vcovHC(model, type = "HC1"))
if (any(robust_test[2:3, 4] < 0.05)) {
significant <- significant + 1
}
}
s3_power[j] <- significant / n_sims
}
s3_table <- data.frame(N_Per_Group = sample_sizes, Power = s3_power)
colnames(s3_table) <- c("N Per Group", "Power")
knitr::kable(s3_table, caption = "Scenario 3: Large Effect (AI 5 min faster, Video 2.5 min faster)")
plot_df <- data.frame(
n = rep(sample_sizes, 3),
power = c(s1_power, s2_power, s3_power),
scenario = factor(rep(c("Small (AI 1 min faster)",
"Medium (AI 3 min faster)",
"Large (AI 5 min faster)"),
each = length(sample_sizes)),
levels = c("Small (AI 1 min faster)",
"Medium (AI 3 min faster)",
"Large (AI 5 min faster)"))
)
ggplot(plot_df, aes(x = n, y = power, color = scenario)) +
geom_line(linewidth = 1.2) +
geom_point(size = 2.5) +
geom_hline(yintercept = 0.80, linetype = "dashed", color = "gray40") +
annotate("text", x = 48, y = 0.83, label = "80% Power", color = "gray40", size = 3.5) +
labs(x = "Sample Size Per Group",
y = "Power",
title = "Simulation-Based Power Analysis\n(1,000 simulations, OLS with robust SEs, alpha = 0.05)",
color = "Scenario") +
theme_minimal(base_size = 12) +
theme(legend.position = "bottom",
plot.title = element_text(hjust = 0.5)) +
scale_y_continuous(limits = c(0, 1), breaks = seq(0, 1, 0.1)) +
scale_x_continuous(breaks = sample_sizes) +
scale_color_manual(values = c("red", "blue", "darkgreen"))
summary_table <- data.frame(
N_Per_Group = sample_sizes,
Small = s1_power,
Medium = s2_power,
Large = s3_power
)
colnames(summary_table) <- c("N Per Group",
"Small (1 min)",
"Medium (3 min)",
"Large (5 min)")
knitr::kable(summary_table, caption = "Power by Sample Size and Scenario")
bookdown::render_book("Sudoku_Experiment_Final_Paper.Rmd", "bookdown::pdf_book")
